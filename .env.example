# ============================================
# Aethera-CRM Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# CLOUDFLARE CONFIGURATION
# ============================================
CLOUDFLARE_ACCOUNT_ID=2c268625d9e6e4c084ff296fcdf5f3bd
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# ============================================
# CLOUDFLARE D1 DATABASE
# ============================================
D1_DATABASE_NAME=aethera-crm-db
D1_DATABASE_ID=your_d1_database_id_here

# ============================================
# CLOUDFLARE AI GATEWAY
# ============================================
AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/aethera-gateway
AI_GEMMA_MODEL=@cf/google/gemma-7b-it
AI_LLAMA_MODEL=@cf/meta/llama-3.1-70b-instruct
AI_MISTRAL_MODEL=@cf/mistral/mistral-7b-instruct-v0.1
AI_EMBEDDING_MODEL=@cf/huggingface/nomic-embed-text-v1.5

# ============================================
# CLOUDFLARE R2 STORAGE
# ============================================
R2_BUCKET_NAME=aethera-crm-storage
R2_BUCKET_ID=your_r2_bucket_id_here

# ============================================
# CLOUDFLARE QUEUES
# ============================================
QUEUES_EMAIL_SYNC_NAME=aethera-email-sync
QUEUES_AI_JOBS_NAME=aethera-ai-jobs
QUEUES_SCRAPING_NAME=aethera-scraping

# ============================================
# USER CONFIGURATION
# ============================================
ADMIN_USERNAME=aethera
ADMIN_PASSWORD=Aetherahealthcare@2026
ADMIN_EMAIL=info@aetherahealthcare.com

# ============================================
# GOOGLE WORKSPACE (Gmail, Calendar)
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# ============================================
# TWILIO CONFIGURATION
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# ============================================
# SELF-HOSTED SERVICES (Local PC)
# ============================================
DOCUSEAL_URL=http://localhost:8080
CALCOM_URL=http://localhost:3000
JITSI_URL=http://localhost:8443
N8N_URL=http://localhost:5678

# ============================================
# SCRAPING CONFIGURATION
# ============================================
PROXY_LIST_URL=https://raw.githubusercontent.com/TheSpeedX/PROXY-List/master/http.txt
SCRAPING_DELAY_SECONDS=30
SCRAPING_TIMEOUT_MS=30000
SCRAPING_MAX_RETRIES=3

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=60
BACKUP_EMAIL=info@aetherahealthcare.com
BACKUP_LOCAL_PATH=C:\Aethera-CRM\backups

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8787
JWT_SECRET=your_jwt_secret_here_generate_secure_random_string
JWT_EXPIRY_HOURS=24

# ============================================
# RATE LIMITING
# ============================================
API_RATE_LIMIT_REQUESTS=1000
API_RATE_LIMIT_WINDOW_MS=3600000
